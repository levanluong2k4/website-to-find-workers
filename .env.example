APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

CURL_CA_BUNDLE=
SSL_CERT_FILE=

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
BOOKING_WORKER_REMINDER_MINUTES=30

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth
# Register this callback in Google Cloud Console, or adjust APP_URL if you use another local host/port.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

PHONE_VERIFICATION_REQUIRED=false
PHONE_VERIFICATION_DEMO_ENABLED=true
PHONE_VERIFICATION_DEMO_NUMBERS=0900000001,0900000002,0900000003
PHONE_VERIFICATION_DEMO_CODE=135790
PHONE_VERIFICATION_REAL_ENABLED=false
PHONE_VERIFICATION_REAL_PROVIDER=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_OUTPUT_DIMENSIONALITY=768
GEMINI_EMBEDDING_NORMALIZE_VECTORS=true
GEMINI_TIMEOUT=25
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
GEMINI_FORCE_JSON_RESPONSE=true

QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=ai_knowledge_items_v1
QDRANT_VECTOR_SIZE=768
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT=10
 
 # Cloudinary Configuration
 # Get this from your Cloudinary Dashboard: https://cloudinary.com/console
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_UPLOAD_PRESET=

VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_BANK_CODE=
VNP_EXPIRE_MINUTES=15
VNP_TIMEZONE=Asia/Ho_Chi_Minh
PAYMENT_CALLBACK_BASE_URL=

MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_KEY2=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_QUERY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/query
ZALOPAY_TIMEZONE=Asia/Ho_Chi_Minh
ZALOPAY_EXPIRE_DURATION_SECONDS=900
ZALOPAY_BANK_CODE=
ZALOPAY_PREFERRED_PAYMENT_METHODS=zalopay_wallet
