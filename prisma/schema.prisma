generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  customer
  worker
}

enum ChatMagicSender {
  user
  assistant
  system
}

enum DonDatLichLoaiDatLich {
  at_home
  at_store
}

enum DonDatLichTrangThai {
  cho_xac_nhan
  da_xac_nhan
  dang_lam
  cho_hoan_thanh
  cho_thanh_toan
  da_xong
  da_huy
}

enum HoSoThoTrangThaiDuyet {
  cho_duyet
  da_duyet
  tu_choi
}

enum ThanhToanPhuongThuc {
  cash
  vnpay
  momo
  zalopay
}

enum ThanhToanTrangThai {
  pending
  success
  failed
}

model User {
  id                         BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  name                       String        @db.VarChar(255)
  email                      String        @unique(map: "users_email_unique") @db.VarChar(255)
  password                   String        @db.VarChar(255)
  phone                      String?       @db.VarChar(255)
  role                       UserRole      @default(customer)
  is_active                  Boolean       @default(true) @db.TinyInt
  created_at                 DateTime?     @db.Timestamp(0)
  chat_magic                 ChatMagic[]
  ho_so_tho                  HoSoTho?
  don_dat_lich_khach_hang    DonDatLich[]  @relation("KhachHangBookings")
  don_dat_lich_tho           DonDatLich[]  @relation("ThoBookings")
  danh_gia_nguoi_danh_gia    DanhGia[]     @relation("NguoiDanhGia")
  danh_gia_nguoi_bi_danh_gia DanhGia[]     @relation("NguoiBiDanhGia")
  tho_dich_vu                ThoDichVu[]

  @@map("users")
}

model DanhMucDichVu {
  id                   BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  ten_dich_vu          String             @db.VarChar(255)
  mo_ta                String?            @db.VarChar(255)
  trang_thai           Boolean            @default(true) @db.TinyInt
  created_at           DateTime?          @db.Timestamp(0)
  don_dat_lich_dich_vu DonDatLichDichVu[]
  tho_dich_vu          ThoDichVu[]

  @@map("danh_muc_dich_vu")
}

model ChatMagic {
  id          BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  user_id     BigInt?         @db.UnsignedBigInt
  guest_token String?         @db.VarChar(100)
  sender      ChatMagicSender @default(user)
  text        String          @db.LongText
  created_at  DateTime        @default(now()) @db.Timestamp(0)
  user        User?           @relation(fields: [user_id], references: [id], onDelete: SetNull, map: "chat_magic_user_id_foreign")

  @@index([user_id], map: "chat_magic_user_id_foreign")
  @@map("chat_magic")
}

model HoSoTho {
  id                  BigInt                  @id @default(autoincrement()) @db.UnsignedBigInt
  user_id             BigInt                  @unique(map: "ho_so_tho_user_id_unique") @db.UnsignedBigInt
  cccd                String                  @unique(map: "ho_so_tho_cccd_unique") @db.VarChar(255)
  kinh_nghiem         String?                 @db.Text
  ban_kinh_phuc_vu    Int                     @default(10)
  trang_thai_duyet    HoSoThoTrangThaiDuyet  @default(cho_duyet)
  danh_gia_trung_binh Decimal                 @default(0.00) @db.Decimal(3, 2)
  created_at          DateTime?               @db.Timestamp(0)
  user                User                    @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "ho_so_tho_user_id_foreign")

  @@map("ho_so_tho")
}

model DonDatLich {
  id                   BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  khach_hang_id        BigInt                 @db.UnsignedBigInt
  tho_id               BigInt?                @db.UnsignedBigInt
  loai_dat_lich        DonDatLichLoaiDatLich @default(at_home)
  thoi_gian_hen        DateTime               @db.DateTime(0)
  dia_chi              String                 @db.VarChar(255)
  mo_ta_van_de         String?                @db.Text
  trang_thai           DonDatLichTrangThai    @default(cho_xac_nhan)
  tong_tien            Decimal?               @db.Decimal(15, 2)
  created_at           DateTime?              @db.Timestamp(0)
  khach_hang           User                   @relation("KhachHangBookings", fields: [khach_hang_id], references: [id], onDelete: Cascade, map: "don_dat_lich_khach_hang_id_foreign")
  tho                  User?                  @relation("ThoBookings", fields: [tho_id], references: [id], onDelete: SetNull, map: "don_dat_lich_tho_id_foreign")
  danh_gia             DanhGia[]
  don_dat_lich_dich_vu DonDatLichDichVu[]
  thanh_toan           ThanhToan[]

  @@index([khach_hang_id], map: "don_dat_lich_khach_hang_id_foreign")
  @@index([tho_id], map: "don_dat_lich_tho_id_foreign")
  @@map("don_dat_lich")
}

model DonDatLichDichVu {
  id             BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  don_dat_lich_id BigInt       @db.UnsignedBigInt
  dich_vu_id     BigInt        @db.UnsignedBigInt
  created_at     DateTime?     @db.Timestamp(0)
  don_dat_lich   DonDatLich    @relation(fields: [don_dat_lich_id], references: [id], onDelete: Cascade, map: "don_dat_lich_dich_vu_don_dat_lich_id_foreign")
  dich_vu        DanhMucDichVu @relation(fields: [dich_vu_id], references: [id], onDelete: Cascade, map: "don_dat_lich_dich_vu_dich_vu_id_foreign")

  @@unique([don_dat_lich_id, dich_vu_id], map: "booking_service_unique")
  @@index([dich_vu_id], map: "don_dat_lich_dich_vu_dich_vu_id_foreign")
  @@map("don_dat_lich_dich_vu")
}

model ThoDichVu {
  id         BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt        @db.UnsignedBigInt
  dich_vu_id BigInt        @db.UnsignedBigInt
  created_at DateTime?     @db.Timestamp(0)
  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "tho_dich_vu_user_id_foreign")
  dich_vu    DanhMucDichVu @relation(fields: [dich_vu_id], references: [id], onDelete: Cascade, map: "tho_dich_vu_dich_vu_id_foreign")

  @@index([user_id], map: "tho_dich_vu_user_id_foreign")
  @@index([dich_vu_id], map: "tho_dich_vu_dich_vu_id_foreign")
  @@map("tho_dich_vu")
}

model ThanhToan {
  id              BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  don_dat_lich_id BigInt              @db.UnsignedBigInt
  so_tien         Decimal             @db.Decimal(12, 2)
  phuong_thuc     ThanhToanPhuongThuc @default(cash)
  trang_thai      ThanhToanTrangThai  @default(pending)
  created_at      DateTime?           @db.Timestamp(0)
  don_dat_lich    DonDatLich          @relation(fields: [don_dat_lich_id], references: [id], onDelete: Cascade, map: "thanh_toan_don_dat_lich_id_foreign")

  @@index([don_dat_lich_id], map: "thanh_toan_don_dat_lich_id_foreign")
  @@map("thanh_toan")
}

model DanhGia {
  id                   BigInt     @id @default(autoincrement()) @db.UnsignedBigInt
  don_dat_lich_id      BigInt     @db.UnsignedBigInt
  nguoi_danh_gia_id    BigInt     @db.UnsignedBigInt
  nguoi_bi_danh_gia_id BigInt     @db.UnsignedBigInt
  so_sao               Int
  nhan_xet             String?    @db.Text
  created_at           DateTime?  @db.Timestamp(0)
  don_dat_lich         DonDatLich @relation(fields: [don_dat_lich_id], references: [id], onDelete: Cascade, map: "danh_gia_don_dat_lich_id_foreign")
  nguoi_danh_gia       User       @relation("NguoiDanhGia", fields: [nguoi_danh_gia_id], references: [id], onDelete: Cascade, map: "danh_gia_nguoi_danh_gia_id_foreign")
  nguoi_bi_danh_gia    User       @relation("NguoiBiDanhGia", fields: [nguoi_bi_danh_gia_id], references: [id], onDelete: Cascade, map: "danh_gia_nguoi_bi_danh_gia_id_foreign")

  @@index([don_dat_lich_id], map: "danh_gia_don_dat_lich_id_foreign")
  @@index([nguoi_danh_gia_id], map: "danh_gia_nguoi_danh_gia_id_foreign")
  @@index([nguoi_bi_danh_gia_id], map: "danh_gia_nguoi_bi_danh_gia_id_foreign")
  @@map("danh_gia")
}
